rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is an admin
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email == "sipencil@gmail.com" || 
              request.auth.token.email == "ngerjaindiri@gmail.com" || 
              request.auth.token.email == "abiemputra.asn@gmail.com");
    }

    // Rules for the employees collection
    match /shared/data/employees/{employeeId} {
      // Allow any authenticated user to read
      allow read: if request.auth != null;
      
      // Only designated admins can create, update, or delete
      allow write: if isAdmin();
    }

    // Default deny for all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
